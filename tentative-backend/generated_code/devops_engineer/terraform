# File: main.tf
# Purpose: Provision AWS infrastructure for the cookie website.
# Dependencies: Terraform AWS Provider, PostgreSQL RDS module.

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 4.0"
    }
  }

  required_version = ">= 1.3.0"
}

provider "aws" {
  region = "us-east-1" # Adjust based on your preferred region
}

# Define S3 bucket for static file hosting
resource "aws_s3_bucket" "static_assets" {
  bucket = "cookie-website-static-assets"
  acl    = "public-read"

  cors_rule {
    allowed_headers = ["*"]
    allowed_methods = ["GET"]
    allowed_origins = ["*"]
    max_age_seconds = 3000
  }

  website {
    index_document = "index.html"
    error_document = "error.html"
  }

  tags = {
    Name        = "CookieWebsiteS3"
    Environment = "Production"
  }
}

# Define EC2 instance for backend hosting
resource "aws_instance" "backend_server" {
  ami           = "ami-0c02fb55956c7d316" # Amazon Linux 2 AMI
  instance_type = "t3.micro"

  key_name = "cookie-website-key" # Ensure this key pair exists in your AWS account

  user_data = <<-EOF
              #!/bin/bash
              yum update -y
              yum install -y docker
              service docker start
              usermod -a -G docker ec2-user
              curl -fsSL https://get.docker.com/ | sh
              docker run -d -p 8080:8080 mybackend:latest
              EOF

  tags = {
    Name        = "CookieWebsiteBackend"
    Environment = "Production"
  }
}

# Define RDS PostgreSQL database
module "db" {
  source  = "terraform-aws-modules/rds/aws"
  version = "~> 5.0"

  identifier = "cookie-website-db"

  engine            = "postgres"
  engine_version    = "14.3"
  instance_class    = "db.t3.micro"
  allocated_storage = 20
  max_allocated_storage = 100
  storage_type      = "gp2"

  username = "admin"
  password = "securepassword123" # Replace with a secure password
  database_name = "cookiewebsite"

  publicly_accessible = false
  vpc_security_group_ids = [
    aws_security_group.rds_sg.id
  ]

  tags = {
    Name        = "CookieWebsiteDB"
    Environment = "Production"
  }
}

# Define security groups
resource "aws_security_group" "web_sg" {
  name        = "cookie-website-web-sg"
  description = "Allow HTTP and HTTPS traffic"

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "CookieWebsiteWebSG"
    Environment = "Production"
  }
}

resource "aws_security_group" "rds_sg" {
  name        = "cookie-website-rds-sg"
  description = "Allow traffic to RDS instance"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/16"] # Replace with your VPC CIDR block
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "CookieWebsiteRDSSG"
    Environment = "Production"
  }
}

# Output the S3 endpoint for reference
output "s3_bucket_website_endpoint" {
  value = aws_s3_bucket.static_assets.website_endpoint
  description = "The endpoint of the S3 bucket for hosting static assets."
}

# Output the backend server public IP
output "backend_server_public_ip" {
  value = aws_instance.backend_server.public_ip
  description = "The public IP address of the backend server."
}
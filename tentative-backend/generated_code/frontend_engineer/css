/* Purpose: Styling for cookie banner and cookie policy page */
.cookie-banner {
  position: fixed;
  bottom: 0;
  width: 100%;
  background-color: #f3f3f3;
  padding: 10px;
  text-align: center;
  border-top: 1px solid #ccc;
}

.cookie-banner p {
  margin: 0;
  padding: 0;
}

.cookie-banner button {
  margin: 0 10px;
  padding: 5px 10px;
}

.cookie-policy {
  padding: 20px;
}
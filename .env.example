# Agentic Nexus Backend - Configuration Template
# Copy this to .env and fill in your values

# ==========================================
# AZURE CREDENTIALS
# ==========================================
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ==========================================
# COSMOS DB
# ==========================================
COSMOS_CONNECTION_STR=DefaultEndpointsProtocol=https://...
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-master-key>
DATABASE_NAME=agentic-nexus-db
LEDGER_CONTAINER=TaskLedgers
AGENT_CONTAINER=AgentRegistry
EXCHANGE_LOG_CONTAINER=AgentExchangeLog

# ==========================================
# AZURE SERVICE BUS
# ==========================================
SERVICE_BUS_STR=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=...
GHOST_HANDSHAKE_QUEUE=agent-handshake-stubs
AGENT_COORDINATION_TOPIC=agent-coordination-events
AGENT_EXECUTION_QUEUE=agent-execution-queue

# ==========================================
# CONTAINER REGISTRY
# ==========================================
AZURE_CONTAINER_REGISTRY=nexusacrteam
ACR_IMAGE_NAME=agentic-nexus
ACR_IMAGE_TAG=latest

# ==========================================
# CONTAINER APPS
# ==========================================
AZURE_CONTAINER_APP_NAME=agentic-nexus-api
AZURE_RESOURCE_GROUP=agentic-nexus-rg
AZURE_CONTAINER_APP_ENVIRONMENT=agentic-nexus-env
AZURE_LOCATION=eastus

# Container configuration
CONTAINER_PORT=8000
CONTAINER_CPU=0.5
CONTAINER_MEMORY=1Gi
CONTAINER_REPLICAS_MIN=1
CONTAINER_REPLICAS_MAX=10

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
STATIC_WEB_APP_DOMAIN=https://<your-static-web-app>.azurestaticapps.net
FRONTEND_URL=https://<your-static-web-app>.azurestaticapps.net
API_BASE_URL=https://<container-app-url>

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=INFO
ENABLE_APPLICATION_INSIGHTS=false
APP_INSIGHTS_KEY=

# ==========================================
# FEATURES
# ==========================================
ENABLE_CODE_GENERATION=true
ENABLE_DEPLOYMENT=true
ENABLE_COST_ESTIMATION=true
MAX_PROJECT_TIMEOUT_SECONDS=3600

# ==========================================
# AUTHENTICATION
# ==========================================
ENABLE_AUTH=false
AUTH_PROVIDER=azure-ad

# ==========================================
# AGENT CONFIGURATION
# ==========================================
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_SECONDS=300
MAX_AGENT_ITERATIONS=15
ENVIRONMENT=production
AGENT_TRACE_MODE=summary
PERSIST_CODE_TO_DB=true
REQUIRE_OUTPUT_FOR_COMPLETION=true
SERVICE_BUS_RETRY_MAX=3
SERVICE_BUS_RETRY_BASE_MS=500
ENABLE_SERVICE_BUS_CONSUMER=false
RFC_BLOCKING_MODE=false
ENABLE_INTERACTIVE_SHELL=false
#COST OPTMIZER
PROJECT_BUDGET_USD=5.0
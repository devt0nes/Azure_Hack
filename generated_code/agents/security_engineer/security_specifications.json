{
  "security_specifications": {
    "encryption": {
      "algorithm": "AES-256",
      "key_storage": {
        "method": "Hardware Security Module (HSM)",
        "rotation_policy": "Every 90 days"
      }
    },
    "authentication": {
      "multi_factor_authentication": true,
      "password_policy": {
        "min_length": 12,
        "complexity_requirements": {
          "uppercase": 1,
          "lowercase": 1,
          "numbers": 1,
          "special_characters": 1
        },
        "rotation_period": "Every 60 days"
      }
    },
    "secrets_management": {
      "tool": "HashiCorp Vault",
      "access_control": {
        "role_based_access_control": true,
        "audit_logs": true
      }
    },
    "compliance": {
      "regulations": ["GDPR", "HIPAA", "SOC2"],
      "data_retention_policy": {
        "default_retention_period": "7 years",
        "exceptions": {
          "financial_data": "10 years",
          "health_data": "As per HIPAA guidelines"
        }
      }
    },
    "threat_assessment": {
      "regularity": "Quarterly",
      "tools": ["OWASP ZAP", "Burp Suite", "Nessus"],
      "reporting": "Detailed report with risk categorization (Critical, High, Medium, Low)"
    }
  }
}